#!/bin/bash
# bolt-greet-run — start bolt-greet with the local UTC offset, logging every
# stage to /tmp/bolt-greet.log so a black screen still leaves evidence.
#
# bolt-greet carries no TZif parser (it would dwarf the greeter), so the
# shell hands it `date +%z` once at startup. DST flips get picked up on the
# next greeter start.
#
# Recovery from a VT test: Esc exits the menu; Ctrl+C restores the console
# (signal handler tears down DRM). Worst case, switch VT and read the log.
LOG=/tmp/bolt-greet.log

# One greeter at a time (the binary also flocks /run/bolt-greet.lock).
if pgrep -x bolt-greet >/dev/null 2>&1; then
    echo "bolt-greet-run: a greeter is already running (pgrep -x bolt-greet)." >&2
    exit 1
fi

# The kernel allows same-uid DRM master takeover, so a running Xorg/frame
# does NOT protect itself against us — starting the greeter over a live
# session steals the panel mid-use. Refuse unless the display is free.
# LIVE check via ss (listening sockets), not ls: a crashed/killed server
# leaves its socket FILE behind, and a dead file must not block the
# greeter. Stale files are cleaned so the session's own X can bind :0.
if ss -xl 2>/dev/null | grep -q '/tmp/\.X11-unix/' && [ "${GREET_FORCE:-0}" != "1" ]; then
    echo "bolt-greet-run: a display server is running (live socket in /tmp/.X11-unix)." >&2
    echo "bolt-greet-run: stop it first (sudo systemctl stop gdm3), or GREET_FORCE=1 to override." >&2
    exit 1
fi
rm -f /tmp/.X11-unix/X* 2>/dev/null

# Stray sweep: everything a greeter tree ever spawns carries GREET_SESSION=1
# (the wrapper exports it below; bolt-greet passes it to sessions). With no
# display server running (guard above), any process still carrying it is a
# leftover from a previous run — kill by exact PID, never by name. Two
# passes: TERM, then KILL for anything ignoring it.
sweep(){
    local sig=$1 found=0
    for d in /proc/[0-9]*/environ; do
        local p=${d%/environ}; p=${p#/proc/}
        [ "$p" = "$$" ] && continue
        if grep -qzs 'GREET_SESSION=1' "$d" 2>/dev/null; then
            found=1
            [ "$sig" = "-TERM" ] && echo "bolt-greet-run: killing stray $p ($(tr '\0' ' ' < /proc/$p/cmdline 2>/dev/null | head -c 50))" >&2
            kill "$sig" "$p" 2>/dev/null
        fi
    done
    return $((1 - found))
}
if sweep -TERM; then sleep 0.5; sweep -KILL; sleep 0.2; fi
export GREET_SESSION=1

: > "$LOG"
# Own VT number: evdev input is global, so bolt-greet gates keys on the
# active VT and hands the display back when you switch away (Alt+F-keys).
VT=$(tty 2>/dev/null | grep -o '[0-9]*$')
/usr/local/bin/bolt-greet --tz "$(date +%z)" --vt "${VT:-0}" "$@" 2> >(tee -a "$LOG" >&2)
rc=$?
# The greeter reads keyboards via evdev; the same keystrokes also landed in
# this VT's tty buffer. Drain them so they don't execute in the shell.
while read -r -t 0.1 _ 2>/dev/null; do :; done
echo "bolt-greet exited ($rc) — log: $LOG"
exit $rc
