#!/bin/bash
# greet-session <1|2|3> — launched by bolt-greet (as root, DRM released).
#   1 = tile on frame     (frame is the X server, root; session as user)
#   2 = tile on X         (Xorg as root; session as user — the gdm split)
#   3 = i3 on X           (safeguard)
# Returns when the session ends; bolt-greet then redraws its menu.
set -u
CH="${1:-1}"

# The user the session runs as. Single-user machine; keep it simple.
U=geir
UHOME=/home/geir
UID_N=1000

ts(){ echo "greet-session: $* [$(date +%T)]" >&2; }

if [ "$CH" = "1" ]; then
    # frame brings its own DRM + input handling; the script starts tile and
    # the full ~/.tilerc autostart as $U. GREETER=1 = non-interactive exit
    # (no "restart gdm?" prompt — control returns to bolt-greet instead).
    # HOME: bolt-greet's children get HOME=/root; the script builds every
    # binary path from $HOME (BASE="$HOME/Main/...") — without this it
    # exits instantly on "missing binary" (the press-1-flicker).
    GREETER=1 HOME="$UHOME" exec bash "$UHOME/Main/G/GIT-isene/frame/test/desktop-on-frame.sh"
fi

# --- X sessions: root Xorg + user session, same privileged/unprivileged
# --- split as frame (and as gdm). Auth via a throwaway xauth cookie.
VT="vt$(fgconsole 2>/dev/null || echo 1)"
XAUTH=/run/bolt-greet.xauth
rm -f "$XAUTH" "$XAUTH-c" "$XAUTH-l" /tmp/.X11-unix/X0
# Generate the cookie AS ROOT: xauth creates lock files next to the target,
# and geir cannot write /run — the runuser variant timed out silently and
# left a 0-byte cookie file (every CHasm client then connected cookie-less
# and tile's phantom auth bytes desynced the server). chown after, so the
# session's clients can read it.
xauth -q -f "$XAUTH" add :0 MIT-MAGIC-COOKIE-1 "$(mcookie)" 2>&1 | head -2 >&2
chown "$U:$U" "$XAUTH"
if [ ! -s "$XAUTH" ]; then
    echo "greet-session: FATAL: cookie file empty after xauth add" >&2
    exit 1
fi

# Run Xorg OUTSIDE any logind session (transient systemd unit — what real
# display managers do). Inside a session, Xorg's logind integration takes
# over and logind hands it a PAUSED drm fd whenever it disagrees about the
# active session ("no screens found"); its fallback then probes the wrong
# card. With no session to take control of, Xorg opens DRM directly as
# root and finds card1 via udev.
XUNIT=bolt-greet-x
systemctl reset-failed "$XUNIT" 2>/dev/null
systemctl stop "$XUNIT" 2>/dev/null

ts "starting Xorg on $VT"
systemd-run --unit="$XUNIT" --collect --quiet \
    -p StandardOutput=append:/tmp/bolt-greet-xorg.log \
    -p StandardError=append:/tmp/bolt-greet-xorg.log \
    /usr/lib/xorg/Xorg :0 "$VT" -auth "$XAUTH" -noreset
for _ in $(seq 1 50); do [ -e /tmp/.X11-unix/X0 ] && break; sleep 0.1; done
# Socket existing is not "up" — probe with a real client before launching
# the session (a "no screens found" Xorg dies right after binding).
XOK=0
for _ in $(seq 1 30); do
    if runuser -u "$U" -- env DISPLAY=:0 XAUTHORITY="$XAUTH" xdpyinfo \
        >/dev/null 2>&1; then XOK=1; break; fi
    systemctl is-active --quiet "$XUNIT" || break
    sleep 0.1
done
if [ "$XOK" != "1" ]; then
    echo "greet-session: Xorg failed:" >&2
    tail -5 /tmp/bolt-greet-xorg.log >&2
    systemctl stop "$XUNIT" 2>/dev/null
    exit 1
fi
ts "Xorg up"

# Warm up RandR before the WM starts: a fresh modesetting Xorg may not have
# probed connectors yet, and tile's output discovery then falls back
# (src=F) — its fallback path desyncs the X connection (dead Mod4, no WS
# properties, sluggish session). Query until the panel shows as connected;
# gdm never hits this because its Xorg is up long before the session.
for _ in $(seq 1 30); do
    runuser -u "$U" -- env DISPLAY=:0 XAUTHORITY="$XAUTH" xrandr --query \
        2>/dev/null | grep -q ' connected' && break
    sleep 0.1
done
runuser -u "$U" -- env DISPLAY=:0 XAUTHORITY="$XAUTH" xrandr --query \
    2>/dev/null | grep ' connected' | head -2 >&2
ts "RandR ready"

if [ "$CH" = "3" ]; then
    # i3 safeguard: its own config execs ~/bin/xps14 (the X prologue), so
    # run it plain — wrapping it here ran xps14 twice.
    SESSION=(/usr/bin/i3)
else
    SESSION=("$UHOME/bin/start-tile-session")
fi

# setsid: the session gets its own process group so we can kill EVERYTHING
# it spawned when it ends. Without this, ~/.tilerc children (strip-watchdog,
# firefox, glass, ...) outlive the session as orphans — a leftover
# strip-watchdog respawning strip 1x/s fought the next session's bar/tray.
# MOZ_DISABLE_CONTENT_SANDBOX: apparmor denies userns to a root/runuser-
# launched Firefox (unshare EPERM → content children die); same tradeoff as
# the frame session. XDG_DATA_DIRS: glib needs it for GSettings schemas —
# without it nm-applet crashes at startup (no NM tray icon).
ts "starting session ($CH)"
setsid runuser -u "$U" -- env \
    DISPLAY=:0 XAUTHORITY="$XAUTH" \
    HOME="$UHOME" USER="$U" LOGNAME="$U" SHELL=/bin/bash \
    XDG_RUNTIME_DIR="/run/user/$UID_N" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$UID_N/bus" \
    XDG_DATA_DIRS="/usr/local/share:/usr/share" \
    LANG=en_US.UTF-8 XDG_SESSION_TYPE=x11 \
    MOZ_DISABLE_CONTENT_SANDBOX=1 \
    "${SESSION[@]}" &
SPID=$!
wait "$SPID"
ts "session ended"

# Session over: kill its whole process group (exact pgid — never by name),
# then X. TERM first, KILL after a grace period for stragglers.
kill -TERM -- "-$SPID" 2>/dev/null
for _ in $(seq 1 20); do
    pgrep -g "$SPID" >/dev/null 2>&1 || break
    sleep 0.1
done
kill -KILL -- "-$SPID" 2>/dev/null
systemctl stop "$XUNIT" 2>/dev/null
ts "cleaned up"
exit 0
